{
  "title": "ai-gateway · Overview",
  "uid": "aigw-overview",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requests / s by status class",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status_class) (rate(aigw_requests_total[1m]))",
          "legendFormat": "{{status_class}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 latency by provider",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(aigw_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Tokens / s by class",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (token_class) (rate(aigw_tokens_total[5m]))",
          "legendFormat": "{{token_class}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "state-timeline",
      "title": "Circuit breaker state (0 closed / 1 half-open / 2 open)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "aigw_breaker_state",
          "legendFormat": "provider {{provider}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Upstream attempts by outcome",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(aigw_upstream_attempts_total[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Failovers / s",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(aigw_failover_total[5m]))",
          "legendFormat": "failovers"
        }
      ]
    }
  ]
}
